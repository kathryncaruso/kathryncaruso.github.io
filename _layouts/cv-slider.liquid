<!-- ═══════ SLIDER JS ═══════ -->
<script>
  (function () {
    var slider = document.getElementById('detail-slider');
    var body = document.body;
    var sc = document.getElementById('cv-slider-container');

    function updateDetail(level) {
      body.setAttribute('data-detail', level);
      try {
        history.replaceState(null, '', '#detail=' + level);
      } catch (e) {}
    }

    slider.addEventListener('input', function () {
      updateDetail(this.value);
    });

    try {
      var m = window.location.hash.match(/detail=(\d)/);
      if (m) {
        var lv = Math.min(5, Math.max(1, parseInt(m[1])));
        slider.value = lv;
        updateDetail(lv);
      } else {
        updateDetail(slider.value);
      }
    } catch (e) {
      updateDetail(slider.value);
    }

    window.addEventListener(
      'scroll',
      function () {
        sc.classList.toggle('scrolled', window.scrollY > 10);
      },
      { passive: true }
    );
  })();
</script>
