<!-- CV Slider Styles -->
<style>
  /* ═══════════════════════════════════════════════════════════════
     CV SLIDER — scoped styles that work within al-folio's layout
     Uses al-folio CSS variables where possible for theme compat
     ═══════════════════════════════════════════════════════════════ */

  .cv-slider-container {
    position: sticky;
    top: 56px; /* al-folio navbar height */
    z-index: 90;
    background: var(--global-bg-color);
    border-bottom: 1px solid var(--global-divider-color);
    padding: 0.8rem 0;
    margin: 0.5rem -15px 0.5rem;
    transition: box-shadow 0.3s ease;
  }
  .cv-slider-container.scrolled {
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  }
  .cv-slider-inner {
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0 15px;
  }
  .cv-slider-label {
    font-family: 'Roboto', sans-serif;
    font-size: 0.7rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--global-text-color-light);
    white-space: nowrap;
    min-width: 70px;
    line-height: 1.4;
  }
  .cv-slider-label.left {
    text-align: right;
  }
  .cv-slider-label.right {
    text-align: left;
  }
  .cv-slider-track {
    flex: 1;
    position: relative;
    padding-bottom: 14px;
  }
  .cv-slider-track input[type='range'] {
    -webkit-appearance: none;
    appearance: none;
    width: 100%;
    height: 3px;
    background: var(--global-divider-color);
    border-radius: 2px;
    outline: none;
    cursor: pointer;
  }
  .cv-slider-track input[type='range']::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: var(--global-theme-color);
    border: 2.5px solid var(--global-bg-color);
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.2);
    cursor: pointer;
    transition: transform 0.15s ease;
  }
  .cv-slider-track input[type='range']::-webkit-slider-thumb:hover {
    transform: scale(1.15);
  }
  .cv-slider-track input[type='range']::-moz-range-thumb {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: var(--global-theme-color);
    border: 2.5px solid var(--global-bg-color);
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.2);
    cursor: pointer;
  }
  .cv-tick-marks {
    display: flex;
    justify-content: space-between;
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    pointer-events: none;
  }
  .cv-tick-marks span {
    font-size: 0.6rem;
    color: var(--global-text-color-light);
    width: 18px;
    text-align: center;
  }

  /* ═══════ CV CONTENT STYLES ═══════ */

  .cv-content {
    font-family: 'Roboto', sans-serif;
    font-weight: 300;
    -webkit-font-smoothing: antialiased;
  }

  /* ─── HEADER / CONTACT ─── */

  .cv-header {
    text-align: center;
    padding: 0.5rem 0 0.8rem;
    font-family: 'Roboto', sans-serif;
  }
  .cv-header-name {
    font-size: 1.6rem;
    font-weight: 300;
    letter-spacing: 0.04em;
    margin: 0 0 0.15rem;
    color: var(--global-text-color);
  }
  .cv-header-position {
    font-size: 0.92rem;
    font-weight: 400;
    color: var(--global-text-color-light);
    margin: 0 0 0.1rem;
  }
  .cv-header-affiliation {
    font-size: 0.85rem;
    font-weight: 300;
    color: var(--global-text-color-light);
    margin: 0 0 0.6rem;
  }
  .cv-header-affiliation a {
    color: var(--global-theme-color);
    text-decoration: none;
  }
  .cv-header-affiliation a:hover {
    text-decoration: underline;
  }

  .cv-header-links {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.6rem 1.2rem;
    list-style: none;
    padding: 0;
    margin: 0;
    font-size: 0.82rem;
  }
  .cv-header-links li {
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }
  .cv-header-links a {
    color: var(--global-theme-color);
    text-decoration: none;
  }
  .cv-header-links a:hover {
    text-decoration: underline;
  }
  .cv-header-links .cv-icon {
    width: 15px;
    height: 15px;
    opacity: 0.6;
  }

  /* Full contact details at higher detail levels */
  .cv-contact-detail {
    font-size: 0.82rem;
    color: var(--global-text-color-light);
    margin-top: 0.5rem;
    font-family: 'Roboto', sans-serif;
  }

  /* ─── HIGHLIGHTS ─── */

  .cv-highlights {
    margin: 0.8rem 0 0.5rem;
    font-family: 'Roboto', sans-serif;
  }
  .cv-highlights ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .cv-highlights li {
    position: relative;
    padding: 0.35rem 0 0.35rem 1.1rem;
    font-size: 0.9rem;
    line-height: 1.6;
    font-weight: 300;
  }
  .cv-highlights li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.72rem;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--global-theme-color);
  }
  .cv-highlights li strong {
    font-weight: 500;
  }

  .cv-section-title {
    font-family: 'Roboto', sans-serif;
    font-weight: 400;
    font-size: 1.25rem;
    color: var(--global-text-color);
    margin: 2rem 0 0.6rem;
    padding-bottom: 0.3rem;
    border-bottom: 1px solid var(--global-divider-color);
  }

  .cv-subsection-title {
    font-family: 'Roboto', sans-serif;
    font-weight: 500;
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--global-text-color-light);
    margin: 1.2rem 0 0.4rem;
  }

  .cv-entry {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: 0 1.2rem;
    padding: 0.65rem 0;
    border-bottom: 1px solid var(--global-divider-color);
    font-family: 'Roboto', sans-serif;
  }
  .cv-entry:last-child {
    border-bottom: none;
  }

  .cv-entry-date {
    font-size: 0.82rem;
    color: var(--global-text-color-light);
    font-weight: 400;
    padding-top: 0.1rem;
    white-space: nowrap;
  }

  .cv-entry-title {
    font-weight: 400;
    font-size: 0.95rem;
    margin-bottom: 0.1rem;
  }
  .cv-entry-title strong {
    font-weight: 500;
  }

  .cv-entry-org {
    font-size: 0.88rem;
    color: var(--global-text-color-light);
    margin-bottom: 0.15rem;
  }
  .cv-entry-org a {
    color: var(--global-theme-color);
    text-decoration: none;
  }
  .cv-entry-org a:hover {
    text-decoration: underline;
  }

  .cv-entry-detail {
    font-size: 0.88rem;
    line-height: 1.6;
  }
  .cv-entry-detail p {
    margin: 0.2rem 0;
  }
  .cv-entry-detail ul {
    margin: 0.2rem 0 0 1.2rem;
    padding: 0;
  }
  .cv-entry-detail li {
    margin-bottom: 0.15rem;
    font-size: 0.86rem;
  }

  .cv-pub {
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--global-divider-color);
    font-size: 0.88rem;
    line-height: 1.6;
    font-family: 'Roboto', sans-serif;
  }
  .cv-pub:last-child {
    border-bottom: none;
  }
  .cv-pub .pub-number {
    color: var(--global-text-color-light);
    font-size: 0.82rem;
  }
  .cv-pub .authors strong {
    font-weight: 500;
  }
  .cv-pub .venue {
    font-style: italic;
    color: var(--global-text-color-light);
  }

  .cv-list {
    list-style: none;
    padding: 0;
    font-family: 'Roboto', sans-serif;
  }
  .cv-list li {
    padding: 0.4rem 0;
    border-bottom: 1px solid var(--global-divider-color);
    font-size: 0.88rem;
    line-height: 1.55;
  }
  .cv-list li:last-child {
    border-bottom: none;
  }

  .cv-award-amount {
    display: inline-block;
    color: var(--global-text-color-light);
    font-size: 0.82rem;
    margin-left: 0.3rem;
  }
  .cv-award-note {
    display: block;
    color: var(--global-text-color-light);
    font-size: 0.82rem;
    font-style: italic;
  }

  .cv-skills-category {
    margin: 0.6rem 0;
    font-family: 'Roboto', sans-serif;
  }
  .cv-skills-label {
    font-weight: 500;
    font-size: 0.85rem;
    margin-bottom: 0.3rem;
  }
  .cv-skills-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }
  .cv-skill-tag {
    background: var(--global-card-bg-color, #f0f0f0);
    color: var(--global-text-color-light);
    padding: 0.2rem 0.65rem;
    border-radius: 3px;
    font-size: 0.78rem;
    font-weight: 400;
    border: 1px solid var(--global-divider-color);
  }

  /* ═══════ DETAIL LEVEL VISIBILITY ═══════ */
  [data-level] {
    transition:
      opacity 0.3s ease,
      max-height 0.4s ease,
      margin 0.3s ease,
      padding 0.3s ease;
    overflow: hidden;
  }
  [data-level] {
    opacity: 1;
    max-height: 5000px;
  }

  body[data-detail='1'] [data-level='2'],
  body[data-detail='1'] [data-level='3'],
  body[data-detail='1'] [data-level='4'],
  body[data-detail='1'] [data-level='5'] {
    opacity: 0;
    max-height: 0;
    margin: 0;
    padding: 0;
    border-color: transparent;
    overflow: hidden;
    pointer-events: none;
  }
  body[data-detail='2'] [data-level='3'],
  body[data-detail='2'] [data-level='4'],
  body[data-detail='2'] [data-level='5'] {
    opacity: 0;
    max-height: 0;
    margin: 0;
    padding: 0;
    border-color: transparent;
    overflow: hidden;
    pointer-events: none;
  }
  body[data-detail='3'] [data-level='4'],
  body[data-detail='3'] [data-level='5'] {
    opacity: 0;
    max-height: 0;
    margin: 0;
    padding: 0;
    border-color: transparent;
    overflow: hidden;
    pointer-events: none;
  }
  body[data-detail='4'] [data-level='5'] {
    opacity: 0;
    max-height: 0;
    margin: 0;
    padding: 0;
    border-color: transparent;
    overflow: hidden;
    pointer-events: none;
  }

  @media print {
    .cv-slider-container {
      display: none !important;
    }
    .cv-entry {
      break-inside: avoid;
    }
    .cv-highlights {
      break-inside: avoid;
    }
  }

  @media (max-width: 640px) {
    .cv-entry {
      grid-template-columns: 1fr;
      gap: 0;
    }
    .cv-entry-date {
      margin-bottom: 0.05rem;
    }
    .cv-slider-label {
      min-width: 55px;
      font-size: 0.65rem;
    }
    .cv-slider-container {
      top: 0;
    }
    .cv-header-name {
      font-size: 1.35rem;
    }
    .cv-header-links {
      gap: 0.4rem 0.8rem;
    }
  }
</style>

